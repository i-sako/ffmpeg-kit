prefix=/Users/isamusakou/Documents/work/ffmpeg-kit/prebuilt/android-x86/libpng
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/libpng16

Name: libpng
Description: Loads and saves PNG files
Version: 1.6.40
Requires.private: zlib
Libs: -L${libdir} -lpng16
Libs.private: -lm -lz 
Cflags: -I${includedir}
